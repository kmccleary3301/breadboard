{
  "id": "vscode_v5e_bracketed_paste_observer",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5E_PASTE_PRE\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5E_PASTE_PRE",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "paste",
      "text": "\u001b[200~Draft paste marker check\nwith two lines\u001b[201~"
    },
    {
      "kind": "sleep",
      "ms": 800
    },
    {
      "kind": "screenshot",
      "label": "01-bracketed-paste-visible"
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Draft paste marker check"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "with two lines"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "[200~"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "[201~"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "[200~"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "[201~"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        }
      ]
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "terminate"
    }
  ]
}
