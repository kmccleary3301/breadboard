{
  "id": "vscode_transcript_viewer_open_return",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "env": {
    "BREADBOARD_DEFAULT_CONFIG": "$BREADBOARD_REPO_ROOT/agent_configs/misc/breadboard_tui_smoke_chat.yaml",
    "BREADBOARD_SMOKE_CHAT_CONTENT": "TRANSCRIPTOKDONE\n\nTASK COMPLETE\n\n>>>>>> END RESPONSE"
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_VSCODE_PRE_ALPHA\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_VSCODE_PRE_ALPHA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "echo BB_VSCODE_PRE_BETA\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_VSCODE_PRE_BETA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "Reply with the single word formed by joining TRANSCRIPT, OK, and DONE with no separators.\r"
    },
    {
      "kind": "waitForText",
      "text": "TRANSCRIPTOKDONE",
      "timeoutMs": 120000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 1000,
      "timeoutMs": 20000
    },
    {
      "kind": "key",
      "key": "ctrlt"
    },
    {
      "kind": "waitForText",
      "text": "breadboard transcript viewer",
      "timeoutMs": 12000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "transcript-open"
    },
    {
      "kind": "key",
      "key": "ctrlt"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "raw",
          "text": "TRANSCRIPTOKDONE"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Type your request"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "BREADBOARD_SMOKE_CHAT_CONTENT"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Transcript saved"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Saved to"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "\u001b[200~"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "\u001b[201~"
        },
        {
          "kind": "countAtMost",
          "scope": "viewport",
          "text": "Type your request",
          "count": 1
        },
        {
          "kind": "countAtMost",
          "scope": "viewport",
          "text": "[ready]",
          "count": 1
        }
      ]
    },
    {
      "kind": "terminate"
    }
  ],
  "assertions": [
    {
      "kind": "contains",
      "scope": "raw",
      "text": "TRANSCRIPTOKDONE"
    },
    {
      "kind": "contains",
      "scope": "viewport",
      "text": "Type your request"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "BREADBOARD_SMOKE_CHAT_CONTENT"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "You are Codex"
    },
    {
      "kind": "notContains",
      "scope": "buffer",
      "text": "file://logging/"
    },
    {
      "kind": "notContains",
      "scope": "viewport",
      "text": "Transcript saved"
    },
    {
      "kind": "notContains",
      "scope": "viewport",
      "text": "Saved to"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "\u001b[200~"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "\u001b[201~"
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "Type your request",
      "count": 1
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "[ready]",
      "count": 1
    }
  ]
}
