{
  "id": "vscode_v5g_retry_command_semantics",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    { "kind": "write", "text": "echo BB_V5G_RETRY_PRE_ALPHA\r" },
    { "kind": "waitForText", "text": "BB_V5G_RETRY_PRE_ALPHA", "timeoutMs": 8000 },
    { "kind": "write", "text": "bb\r" },
    { "kind": "waitForText", "text": "Type your request", "timeoutMs": 20000 },
    { "kind": "waitForStableFrame", "scope": "viewport", "stableMs": 700, "timeoutMs": 8000 },
    { "kind": "write", "text": "First print RETRYFIRSTSTART. Then write at least fifty short numbered lines. End with exactly R1 followed immediately by OK with no spaces.\r" },
    { "kind": "waitForText", "text": "RETRYFIRSTSTART", "timeoutMs": 120000 },
    { "kind": "key", "key": "escape" },
    { "kind": "sleep", "ms": 1200 },
    { "kind": "key", "key": "ctrlc" },
    { "kind": "waitForText", "text": "Type your request", "timeoutMs": 30000 },
    { "kind": "screenshot", "label": "01-after-stop" },
    { "kind": "write", "text": "/retry\r" },
    { "kind": "waitForText", "text": "Resubmitting prompt", "timeoutMs": 30000 },
    { "kind": "waitForRegex", "pattern": "R1OK", "timeoutMs": 180000 },
    { "kind": "waitForStableFrame", "scope": "viewport", "stableMs": 900, "timeoutMs": 20000 },
    { "kind": "screenshot", "label": "02-after-retry-settled" },
    { "kind": "exportBreadBoardState", "label": "v5g-retry-state" },
    { "kind": "assert", "assertions": [
      { "kind": "contains", "scope": "raw", "text": "BB_V5G_RETRY_PRE_ALPHA" },
      { "kind": "contains", "scope": "raw", "text": "RETRYFIRSTSTART" },
      { "kind": "contains", "scope": "raw", "text": "Resubmitting prompt" },
      { "kind": "regex", "scope": "raw", "pattern": "R1OK" },
      { "kind": "contains", "scope": "viewport", "text": "Type your request" },
      { "kind": "notContains", "scope": "raw", "text": "You are Codex" },
      { "kind": "notContains", "scope": "buffer", "text": "file://logging/" }
    ] },
    { "kind": "terminate" }
  ]
}
