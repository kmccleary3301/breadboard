{
  "id": "vscode_v5d_command_surface_cleanliness",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5D_PRE && bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 25000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 10000
    },
    {
      "kind": "screenshot",
      "label": "00-startup"
    },
    {
      "kind": "write",
      "text": "/raw\r"
    },
    {
      "kind": "waitForText",
      "text": "raw event viewer",
      "timeoutMs": 12000
    },
    {
      "kind": "screenshot",
      "label": "01-raw-viewer"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 500,
      "timeoutMs": 12000
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "raw event viewer"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Status [raw] {"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "● Raw · {"
        }
      ]
    },
    {
      "kind": "screenshot",
      "label": "01b-after-raw-exit"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 12000
    },
    {
      "kind": "write",
      "text": "/copy transcript\r"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 800,
      "timeoutMs": 12000
    },
    {
      "kind": "screenshot",
      "label": "02-copy-transcript"
    },
    {
      "kind": "write",
      "text": "/remote on\r"
    },
    {
      "kind": "waitForText",
      "text": "Remote streaming preference enabled",
      "timeoutMs": 12000
    },
    {
      "kind": "write",
      "text": "/remote off\r"
    },
    {
      "kind": "waitForText",
      "text": "Remote streaming preference disabled",
      "timeoutMs": 12000
    },
    {
      "kind": "screenshot",
      "label": "03-remote-toggle"
    },
    {
      "kind": "write",
      "text": "/mode plan\r"
    },
    {
      "kind": "waitForText",
      "text": "Mode set request sent (plan)",
      "timeoutMs": 12000
    },
    {
      "kind": "write",
      "text": "/mode build\r"
    },
    {
      "kind": "waitForText",
      "text": "Mode set request sent (build)",
      "timeoutMs": 12000
    },
    {
      "kind": "write",
      "text": "/mode auto\r"
    },
    {
      "kind": "waitForText",
      "text": "Mode set request sent (auto)",
      "timeoutMs": 12000
    },
    {
      "kind": "screenshot",
      "label": "04-mode-cycle"
    },
    {
      "kind": "write",
      "text": "/rewind\r"
    },
    {
      "kind": "waitForText",
      "text": "Rewind checkpoints",
      "timeoutMs": 12000
    },
    {
      "kind": "screenshot",
      "label": "05-rewind"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 500,
      "timeoutMs": 12000
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Rewind checkpoints"
        }
      ]
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 12000
    },
    {
      "kind": "write",
      "text": "/clear\r"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 800,
      "timeoutMs": 12000
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Rewind checkpoints"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "● [command]"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Status [raw] {"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Transcript saved"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Mode set request"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Requested checkpoint list"
        },
        {
          "kind": "notContains",
          "scope": "viewport",
          "text": "Loaded 1 checkpoint"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Type your request"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "BreadBoard v0.2.0"
        }
      ]
    },
    {
      "kind": "screenshot",
      "label": "06-after-clear"
    },
    {
      "kind": "terminate"
    }
  ],
  "assertions": [
    {
      "kind": "contains",
      "scope": "raw",
      "text": "BB_V5D_PRE"
    },
    {
      "kind": "contains",
      "scope": "raw",
      "text": "raw event viewer"
    },
    {
      "kind": "notContains",
      "scope": "buffer",
      "text": "Transcript saved\n/tmp/"
    },
    {
      "kind": "notContains",
      "scope": "viewport",
      "text": "Status [raw] {"
    },
    {
      "kind": "notContains",
      "scope": "viewport",
      "text": "● Raw · {"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "You are Codex"
    },
    {
      "kind": "notContains",
      "scope": "buffer",
      "text": "file://logging/"
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "Type your request",
      "count": 1
    }
  ]
}
