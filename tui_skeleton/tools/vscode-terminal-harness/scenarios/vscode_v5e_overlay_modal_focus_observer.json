{
  "id": "vscode_v5e_overlay_modal_focus_observer",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5E_OVERLAY_PRE\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5E_OVERLAY_PRE",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "00-startup"
    },
    {
      "kind": "write",
      "text": "/models\r"
    },
    {
      "kind": "waitForRegex",
      "pattern": "(Models|models|Model|model|gpt)",
      "timeoutMs": 15000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "01-models-wide-open"
    },
    {
      "kind": "resize",
      "cols": 80,
      "rows": 26
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "02-models-narrow-open"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "/todos\r"
    },
    {
      "kind": "waitForRegex",
      "pattern": "(Todos|todos|Todo|todo)",
      "timeoutMs": 12000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "03-todos-open"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "/usage\r"
    },
    {
      "kind": "waitForRegex",
      "pattern": "(Usage|usage|Token|token)",
      "timeoutMs": 12000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "04-usage-open-before-command"
    },
    {
      "kind": "write",
      "text": "/status\r"
    },
    {
      "kind": "sleep",
      "ms": 800
    },
    {
      "kind": "screenshot",
      "label": "05-usage-after-status-typed"
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "screenshot",
      "label": "06-after-usage-escape"
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Type your request"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "[ready]"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        }
      ]
    },
    {
      "kind": "terminate"
    }
  ]
}
