{
  "id": "vscode_model_picker_resize_close",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_VSCODE_PRE_ALPHA\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_VSCODE_PRE_ALPHA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "echo BB_VSCODE_PRE_BETA\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_VSCODE_PRE_BETA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "/models\r"
    },
    {
      "kind": "waitForRegex",
      "pattern": "(Model|model|gpt|Picker|picker)",
      "timeoutMs": 15000
    },
    {
      "kind": "resize",
      "cols": 90,
      "rows": 28
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "key",
      "key": "escape"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Type your request"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "[ready]"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "harness-resize-probe"
        },
        {
          "kind": "countAtMost",
          "scope": "viewport",
          "text": "Type your request",
          "count": 1
        },
        {
          "kind": "countAtMost",
          "scope": "viewport",
          "text": "[ready]",
          "count": 1
        }
      ]
    },
    {
      "kind": "screenshot",
      "label": "after-close"
    },
    {
      "kind": "terminate"
    }
  ],
  "assertions": [
    {
      "kind": "contains",
      "scope": "viewport",
      "text": "Type your request"
    },
    {
      "kind": "contains",
      "scope": "viewport",
      "text": "[ready]"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "You are Codex"
    },
    {
      "kind": "notContains",
      "scope": "buffer",
      "text": "file://logging/"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "harness-resize-probe"
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "Type your request",
      "count": 1
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "[ready]",
      "count": 1
    }
  ]
}
