{
  "id": "vscode_v5g_busy_queue_semantics",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5G_QUEUE_PRE_ALPHA\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5G_QUEUE_PRE_ALPHA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "Use your shell tool exactly once to run: bash -lc 'echo QUEUEFIRSTSTART; sleep 8; echo QUEUEFIRSTEND'. After the tool completes, reply with exactly Q1 followed immediately by OK with no spaces.\r"
    },
    {
      "kind": "waitForText",
      "text": "QUEUEFIRSTSTART",
      "timeoutMs": 120000
    },
    {
      "kind": "write",
      "text": "Reply with exactly Q2 followed immediately by OK with no spaces and no other words.\r"
    },
    {
      "kind": "sleep",
      "ms": 900
    },
    {
      "kind": "screenshot",
      "label": "01-queued-while-busy"
    },
    {
      "kind": "resize",
      "cols": 82,
      "rows": 28,
      "settleMs": 700
    },
    {
      "kind": "screenshot",
      "label": "02-queued-after-resize"
    },
    {
      "kind": "waitForRegex",
      "timeoutMs": 120000,
      "pattern": "Q2OK"
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 900,
      "timeoutMs": 20000
    },
    {
      "kind": "screenshot",
      "label": "03-queue-settled"
    },
    {
      "kind": "exportBreadBoardState",
      "label": "v5g-queue-state"
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "raw",
          "text": "BB_V5G_QUEUE_PRE_ALPHA"
        },
        {
          "kind": "contains",
          "scope": "raw",
          "text": "QUEUEFIRSTSTART"
        },
        {
          "kind": "regex",
          "scope": "raw",
          "pattern": "Q2OK"
        },
        {
          "kind": "contains",
          "scope": "viewport",
          "text": "Type your request"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        }
      ]
    },
    {
      "kind": "terminate"
    }
  ]
}
