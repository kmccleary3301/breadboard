{
  "id": "vscode_default_startup_stale_context_guard",
  "v5ExpectedAssistantText": "BB_V5_FRESH_CONTEXT_OK",
  "v5PromptPattern": "BB_V5_FRESH_CONTEXT_OK|fresh context",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5_STARTUP_PRE_ALPHA && pwd\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5_STARTUP_PRE_ALPHA",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 25000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 10000
    },
    {
      "kind": "screenshot",
      "label": "00-startup"
    },
    {
      "kind": "write",
      "text": "Reply with exactly BB_V5_FRESH_CONTEXT_OK and no other words.\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5_FRESH_CONTEXT_OK",
      "timeoutMs": 180000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 1200,
      "timeoutMs": 30000
    },
    {
      "kind": "screenshot",
      "label": "01-fresh-response"
    },
    {
      "kind": "terminate"
    }
  ],
  "assertions": [
    {
      "kind": "contains",
      "scope": "raw",
      "text": "BB_V5_STARTUP_PRE_ALPHA"
    },
    {
      "kind": "contains",
      "scope": "raw",
      "text": "BB_V5_FRESH_CONTEXT_OK"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "I'm ready to continue"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "I’m ready to continue"
    },
    {
      "kind": "notContains",
      "scope": "raw",
      "text": "You are Codex"
    },
    {
      "kind": "notContains",
      "scope": "buffer",
      "text": "file://logging/"
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "Type your request",
      "count": 1
    },
    {
      "kind": "countAtMost",
      "scope": "viewport",
      "text": "[ready]",
      "count": 1
    }
  ]
}
