{
  "id": "vscode_v5f_assistant_role_semantics",
  "terminal": {
    "initialCols": 118,
    "initialRows": 36
  },
  "steps": [
    {
      "kind": "write",
      "text": "echo BB_V5F_ROLE_PRE\r"
    },
    {
      "kind": "waitForText",
      "text": "BB_V5F_ROLE_PRE",
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "bb\r"
    },
    {
      "kind": "waitForText",
      "text": "Type your request",
      "timeoutMs": 20000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 700,
      "timeoutMs": 8000
    },
    {
      "kind": "write",
      "text": "Reply with exactly the single word formed by joining BB, DEEP, MARKDOWN, and OK. Do not call tools. Do not add punctuation.\r"
    },
    {
      "kind": "waitForText",
      "text": "BBDEEPMARKDOWNOK",
      "timeoutMs": 120000
    },
    {
      "kind": "waitForStableFrame",
      "scope": "viewport",
      "stableMs": 1200,
      "timeoutMs": 20000
    },
    {
      "kind": "screenshot",
      "label": "01-markdown-role-after-answer"
    },
    {
      "kind": "exportBreadBoardState",
      "label": "01-markdown-role-after-answer"
    },
    {
      "kind": "assert",
      "assertions": [
        {
          "kind": "contains",
          "scope": "raw",
          "text": "BBDEEPMARKDOWNOK"
        },
        {
          "kind": "notContains",
          "scope": "raw",
          "text": "You are Codex"
        },
        {
          "kind": "notContains",
          "scope": "buffer",
          "text": "file://logging/"
        }
      ]
    },
    {
      "kind": "terminate"
    }
  ]
}
