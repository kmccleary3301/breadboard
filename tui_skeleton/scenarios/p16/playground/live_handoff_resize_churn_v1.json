{
  "schemaVersion": 1,
  "id": "live_handoff_resize_churn_v1",
  "title": "Live Handoff Resize Churn Playground V1",
  "description": "Production-path playground profile that streams assistant markdown, tool stdout, and tool completion through the real controller while resizing, then proves active live regions hand off cleanly into durable transcript state.",
  "tags": ["resize-spine", "live-region", "handoff", "playground", "scrollback"],
  "family": "resize-spine-playground",
  "campaign": "post-p16-resize-resilience-spine",
  "claimScope": "pty",
  "expectedOutcome": { "verdict": "pass" },
  "productionEquivalence": {
    "required": true,
    "claimTier": "S2",
    "allowedSyntheticLayers": ["model", "tool", "time", "workspace"],
    "forbiddenBypass": ["renderer", "transcript-store", "composer", "footer", "scrollback-feed", "live-slot-store", "direct-cell-mutation"]
  },
  "environment": {
    "env": {
      "BREADBOARD_TUI_STRICT_TRANSCRIPT_SAFETY": "1"
    },
    "dummyWorkspace": {
      "gitInit": true,
      "files": [
        { "path": "README.md", "content": "# Live handoff playground\n\nThis workspace is synthetic and must not affect the project checkout.\n" },
        { "path": "src/live_handoff_fixture.c", "content": "int main(void) { return 0; }\n" }
      ]
    },
    "prelaunchShellHistory": [
      { "id": "live-handoff-pre", "kind": "long-wrap", "text": "BB_RESIZE_SPINE_LIVE_HANDOFF_PRE_HISTORY_BEGIN alpha beta gamma delta epsilon zeta eta theta BB_RESIZE_SPINE_LIVE_HANDOFF_PRE_HISTORY_END" }
    ]
  },
  "launch": {
    "mode": "classic",
    "engineMode": "test-owned",
    "startupWait": { "composerReady": true, "timeoutMs": 20000 },
    "timeoutMs": 120000
  },
  "terminal": {
    "lanes": ["pty"],
    "initial": { "cols": 124, "rows": 36 },
    "resizePolicy": "scripted",
    "captureGrid": true,
    "captureScrollback": true,
    "captureScreenshots": true
  },
  "timeline": [
    { "kind": "submit", "text": "Stream markdown and tool output, then prove live handoff stays clean under resize." },
    { "kind": "assistant", "event": { "kind": "start", "streamId": "handoff-assistant", "messageId": "handoff-msg-1", "turn": 1 } },
    { "kind": "assistant", "event": { "kind": "markdown-fixture", "streamId": "handoff-assistant", "fixture": "mixed-mdx", "chunking": { "mode": "syntax", "seed": 11 }, "turn": 1 } },
    { "kind": "waitFor", "target": { "text": "Streaming Markdown" }, "timeoutMs": 45000 },
    { "kind": "resize", "cols": 94, "rows": 26, "settleMs": 180 },
    { "kind": "checkpoint", "id": "assistant-stream-compact", "capture": { "stateDump": true, "grid": true, "scrollback": true } },
    { "kind": "tool", "event": { "kind": "start", "toolId": "handoff-tool", "name": "shell_command", "args": { "cmd": "printf live handoff" }, "turn": 1 } },
    { "kind": "tool", "event": { "kind": "stdout", "toolId": "handoff-tool", "text": "LIVE_HANDOFF_TOOL_LINE_A\nLIVE_HANDOFF_TOOL_LINE_B\nLIVE_HANDOFF_TOOL_LINE_C\n", "stream": true, "turn": 1 } },
    { "kind": "waitFor", "target": { "text": "LIVE_HANDOFF_TOOL_LINE_A" }, "timeoutMs": 45000 },
    { "kind": "resize", "cols": 78, "rows": 22, "settleMs": 180 },
    { "kind": "checkpoint", "id": "tool-stream-narrow", "capture": { "stateDump": true, "grid": true, "scrollback": true } },
    { "kind": "tool", "event": { "kind": "result", "toolId": "handoff-tool", "status": "ok", "summary": "live handoff tool completed", "output": "LIVE_HANDOFF_TOOL_RESULT_OK", "turn": 1 } },
    { "kind": "assistant", "event": { "kind": "complete", "streamId": "handoff-assistant", "finishReason": "stop", "turn": 1 } },
    { "kind": "resize", "cols": 132, "rows": 36, "settleMs": 250 },
    { "kind": "wait", "ms": 500 },
    { "kind": "checkpoint", "id": "final-wide-idle", "capture": { "stateDump": true, "grid": true, "scrollback": true } }
  ],
  "invariants": [
    { "id": "GLOBAL-HOST-HISTORY-PRESERVED", "severity": "blocker" },
    { "id": "GLOBAL-NO-RAW-ANSI", "severity": "blocker" },
    { "id": "GLOBAL-NO-SYSTEM-PROMPT-LEAK", "severity": "blocker" },
    { "id": "GLOBAL-NO-MAX-LISTENERS-WARNING", "severity": "blocker" },
    { "id": "GLOBAL-NO-RETRY-BUDGET-OVERFLOW", "severity": "blocker" },
    { "id": "GLOBAL-NO-DUPLICATE-PROMPT", "severity": "blocker" },
    { "id": "GLOBAL-TRANSCRIPT-ORDER", "severity": "blocker" },
    { "id": "GLOBAL-COMPOSER-VISIBLE", "severity": "blocker" },
    { "id": "GLOBAL-FOOTER-TRUTHFUL", "severity": "blocker" },
    { "id": "RESIZE-ACTION-OBSERVED", "severity": "blocker" },
    { "id": "MD-FINAL-TEXT-COMPLETE", "severity": "blocker" },
    { "id": "MD-NO-STREAMING-PARTIAL-REPLAY", "severity": "blocker" },
    { "id": "TOOL-START-VISIBLE", "severity": "blocker" },
    { "id": "TOOL-STDOUT-BOUNDED", "severity": "blocker" },
    { "id": "TOOL-RESULT-SINGULAR", "severity": "blocker" },
    { "id": "LIVE-NO-STALE-STREAMING-WHEN-IDLE", "severity": "blocker" },
    { "id": "LIVE-NO-PENDING-SLOTS-WHEN-IDLE", "severity": "blocker" },
    { "id": "LIVE-TRANSCRIPT-CELL-IDS-UNIQUE", "severity": "blocker" },
    { "id": "LIVE-DURABLE-DEDUPE-KEYS-UNIQUE", "severity": "blocker" },
    { "id": "DURABLE-PROMPT-IDS-UNIQUE", "severity": "blocker" },
    { "id": "DURABLE-ASSISTANT-FINAL-IDS-UNIQUE", "severity": "blocker" },
    { "id": "DURABLE-TOOL-IDS-UNIQUE", "severity": "blocker" },
    { "id": "DURABLE-RECOVERY-EPISODES-UNIQUE", "severity": "blocker" },
    { "id": "LIVE-HANDOFF-CLEAN-WHEN-IDLE", "severity": "blocker" }
  ],
  "artifacts": { "required": ["manifest", "raw", "grid", "state", "invariant-report", "scrollback", "viewport"] },
  "actionRequirements": {
    "inputSubmitted": "required",
    "assistantStreamStarted": "required",
    "assistantStreamCompleted": "required",
    "assistantInjected": "required",
    "toolStarted": "required",
    "toolCompleted": "required",
    "resizeRequested": "required",
    "resizeObserved": "required",
    "waitTargetsObserved": "required",
    "stateDumpObservedAfterSubmit": "required",
    "stateDumpObservedAfterResize": "required",
    "artifactCaptureComplete": "required"
  },
  "transcriptExpectation": {
    "promptCardinality": "exactly-once",
    "assistantCardinality": "at-least-once",
    "toolCardinality": "at-least-once"
  },
  "hotRegionExpectation": {
    "maxRows": 8,
    "freezeAfterCheckpoint": "final-wide-idle"
  },
  "mutationProfile": {
    "seed": 11,
    "dimensions": ["assistant-stream", "tool-stdout", "live-to-durable-handoff", "wide-to-narrow-resize", "strict-transcript-safety"]
  }
}
