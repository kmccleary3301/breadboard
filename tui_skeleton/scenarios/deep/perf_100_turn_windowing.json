{
  "schemaVersion": 1,
  "id": "perf_100_turn_windowing",
  "title": "100 event-ingested turns performance/windowing smoke",
  "claimScope": "pty",
  "productionEquivalence": {
    "required": true,
    "claimTier": "S2",
    "allowedSyntheticLayers": ["model", "tool", "time", "workspace"],
    "forbiddenBypass": ["renderer", "transcript-store", "composer", "scrollback-feed"]
  },
  "environment": {
    "dummyWorkspace": { "files": [{ "path": "notes.txt", "content": "windowing stress\n" }], "gitInit": true },
    "prelaunchShellHistory": [{ "id": "perf-pre", "text": "BB_V5_PERF_PRE_HISTORY_SENTINEL" }]
  },
  "launch": { "mode": "classic", "engineMode": "test-owned", "startupWait": { "composerReady": true, "timeoutMs": 20000 }, "timeoutMs": 240000 },
  "terminal": { "lanes": ["pty"], "initial": { "cols": 112, "rows": 32 }, "resizePolicy": "scripted", "captureGrid": true, "captureScrollback": true },
  "fixtures": { "seedTurns": { "count": 100, "throughProductionIngestion": true, "contentMix": ["plain", "markdown"] } },
  "timeline": [
    { "kind": "submit", "text": "Confirm the 100-turn seeded transcript is still responsive." },
    { "kind": "assistant", "event": { "kind": "start", "streamId": "s1" } },
    { "kind": "assistant", "event": { "kind": "delta", "streamId": "s1", "text": "The 100-turn seeded transcript remains responsive." } },
    { "kind": "assistant", "event": { "kind": "complete", "streamId": "s1" } },
    { "kind": "waitFor", "target": { "text": "100-turn seeded transcript remains responsive" }, "timeoutMs": 60000 },
    { "kind": "resize", "cols": 76, "rows": 24, "settleMs": 250 },
    { "kind": "checkpoint", "id": "perf-100-final" }
  ],
  "invariants": [
    { "id": "GLOBAL-HOST-HISTORY-PRESERVED", "severity": "blocker" },
    { "id": "GLOBAL-NO-RAW-ANSI", "severity": "blocker" },
    { "id": "GLOBAL-NO-DUPLICATE-PROMPT", "severity": "blocker" },
    { "id": "GLOBAL-COMPOSER-VISIBLE", "severity": "blocker" },
    { "id": "RESIZE-ACTION-OBSERVED", "severity": "blocker" }
  ],
  "artifacts": { "required": ["manifest", "raw", "grid", "state", "invariant-report"] }
}
