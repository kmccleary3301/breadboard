[
  {
    "action": "log",
    "message": "Multiagent taskboard PTY harness start"
  },
  {
    "action": "waitForComposerReady",
    "timeoutMs": 15000
  },
  {
    "action": "type",
    "text": "Delegate SMTP work to reviewer, implementer, and tester agents.",
