  },
  {
    "action": "press",
    "key": "ctrl+t"
  },
  {
    "action": "waitFor",
    "text": "Press / to search",
    "timeoutMs": 5000
  },
  {
    "action": "wait",
    "ms": 450
  },
  {
    "action": "type",
    "text": "/",
    "typingDelayMs": 5
  },
  {
    "action": "waitFor",
    "text": "Search:",
    "timeoutMs": 5000
  },
  {
    "action": "type",
    "text": "ello",
    "typingDelayMs": 5
  },
  {
    "action": "waitFor",
    "text": "Search: ello",
    "timeoutMs": 15000
  },
  {
    "action": "press",
    "key": "enter"
  },
  {
    "action": "snapshot",
    "label": "search-active"
  },
  {
    "action": "press",
    "key": "escape"
  },
