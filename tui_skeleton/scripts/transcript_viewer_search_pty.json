[
  {
    "action": "log",
    "message": "Transcript viewer search PTY start"
  },
  {
    "action": "waitForComposerReady",
    "timeoutMs": 15000
  },
  {
    "action": "type",
    "text": "Hello transcript",
    "typingDelayMs": 10
  },
  {
    "action": "press",
    "key": "enter"
  },
  {
    "action": "waitForState",
