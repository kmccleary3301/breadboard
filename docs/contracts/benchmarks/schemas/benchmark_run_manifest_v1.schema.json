{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/benchmarks/benchmark_run_manifest_v1.schema.json",
  "title": "Benchmark Run Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "benchmark",
    "dataset",
    "subset_id",
    "seed",
    "replay_id",
    "budget"
  ],
  "properties": {
    "schema_version": {
      "const": "benchmark_run_manifest_v1"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark": {
      "type": "string",
      "minLength": 1
    },
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "subset_id": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "replay_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_hash_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "fixture_relpath": {
      "type": "string",
      "minLength": 1
    },
    "fixture_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "dataset_snapshot_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_iterations",
        "max_seconds"
      ],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "max_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
