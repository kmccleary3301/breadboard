{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/benchmarks/evidence_bundle_manifest_v2.schema.json",
  "title": "Evidence Bundle Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "bundle_id",
    "created_at",
    "claim_ids",
    "tier",
    "reproduction",
    "artifacts"
  ],
  "properties": {
    "schema_id": {
      "const": "breadboard.evidence_bundle_manifest.v2"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tier": {
      "type": "string",
      "enum": [
        "tier0_exploratory",
        "tier1_replay",
        "tier2_statistical",
        "tier3_release"
      ]
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands",
        "expected_outputs"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "path",
          "sha256",
          "mime",
          "size_bytes"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "mime": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "schema_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "spend_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "workstream",
        "experiment",
        "run_id",
        "owner",
        "budget_usd"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "workstream": {
          "type": "string",
          "minLength": 1
        },
        "experiment": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "budget_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "lineage": {
      "type": "object"
    }
  }
}
