{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/atp/atp_proof_plan_ir_v1.schema.json",
  "title": "ATP Proof Plan IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "loop_id",
    "goal",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "const": "atp_proof_plan_ir_v1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "loop_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "strategy": {
      "type": "string",
      "enum": [
        "direct",
        "decomposition_first",
        "retrieval_guided",
        "repair_guided"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "step_kind",
          "statement",
          "depends_on"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "step_kind": {
            "type": "string",
            "enum": [
              "retrieve_lemma",
              "decompose_goal",
              "attempt_proof",
              "verify",
              "repair"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected_artifact_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
