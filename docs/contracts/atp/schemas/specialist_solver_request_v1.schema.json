{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/atp/specialist_solver_request_v1.schema.json",
  "title": "ATP Specialist Solver Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "solver_type",
    "problem_ref",
    "budget"
  ],
  "properties": {
    "schema_version": {
      "const": "atp_specialist_solver_request_v1"
    },
    "solver_type": {
      "type": "string",
      "minLength": 1
    },
    "problem_ref": {
      "type": "string",
      "minLength": 1
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_seconds"
      ],
      "properties": {
        "max_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_calls": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "replay_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
