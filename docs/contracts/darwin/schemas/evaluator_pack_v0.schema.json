{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/darwin/evaluator_pack_v0.schema.json",
  "title": "DarwinEvaluatorPackV0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "campaign_id",
    "lane_id",
    "candidate_id",
    "trial_label",
    "shadow_mode",
    "runtime_consumed",
    "evaluator_identity",
    "metric_semantics",
    "invalid_comparison_rules",
    "control_pack",
    "claim_constraints",
    "pack_version",
    "budget_envelope"
  ],
  "properties": {
    "schema": { "const": "breadboard.darwin.evaluator_pack.v0" },
    "campaign_id": { "type": "string", "minLength": 1 },
    "lane_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "trial_label": { "type": "string", "minLength": 1 },
    "shadow_mode": { "type": "boolean" },
    "runtime_consumed": { "type": "boolean" },
    "evaluator_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluator_type", "task_id", "runner_kind"],
      "properties": {
        "evaluator_type": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "runner_kind": { "type": "string", "minLength": 1 }
      }
    },
    "metric_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_metric", "higher_is_better", "score_unit", "success_condition"],
      "properties": {
        "primary_metric": { "type": "string", "minLength": 1 },
        "higher_is_better": { "type": "boolean" },
        "score_unit": { "type": "string", "minLength": 1 },
        "success_condition": { "type": "string", "minLength": 1 }
      }
    },
    "invalid_comparison_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "control_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_perturbation_group", "required_invariants"],
      "properties": {
        "required_perturbation_group": { "type": "string", "minLength": 1 },
        "required_invariants": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "claim_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_target", "comparability_requirements"],
      "properties": {
        "claim_target": { "type": "string", "minLength": 1 },
        "comparability_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "budget_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_class",
        "wall_clock_ms",
        "token_counts",
        "cost_estimate",
        "cost_classification",
        "comparison_class",
        "execution_mode",
        "route_class",
        "cost_source",
        "support_envelope_digest",
        "evaluator_pack_version",
        "replication_reserve_fraction",
        "control_reserve_fraction"
      ],
      "properties": {
        "budget_class": { "type": "string", "minLength": 1 },
        "wall_clock_ms": { "type": "integer", "minimum": 0 },
        "token_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
          "properties": {
            "prompt_tokens": { "type": "integer", "minimum": 0 },
            "completion_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 },
            "cached_input_tokens": { "type": "integer", "minimum": 0 },
            "cache_write_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "cost_estimate": { "type": "number", "minimum": 0.0 },
        "cost_classification": {
          "type": "string",
          "enum": ["exact_local_zero", "estimated_local_nonzero", "usage_present_zero_cost", "estimated_route_priced"]
        },
        "comparison_class": { "type": "string", "minLength": 1 },
        "route_id": { "type": ["string", "null"] },
        "provider_model": { "type": ["string", "null"] },
        "execution_mode": { "type": "string", "enum": ["live", "scaffold"] },
        "route_class": { "type": "string", "minLength": 1 },
        "cost_source": { "type": "string", "minLength": 1 },
        "support_envelope_digest": { "type": "string", "minLength": 64, "maxLength": 64 },
        "comparison_envelope_digest": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 },
        "evaluator_pack_version": { "type": "string", "minLength": 1 },
        "replication_reserve_fraction": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "control_reserve_fraction": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "control_reserve_policy": { "type": "string", "minLength": 1 }
      }
    }
  }
}
