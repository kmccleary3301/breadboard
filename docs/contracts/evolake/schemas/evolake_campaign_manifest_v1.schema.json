{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/evolake/evolake_campaign_manifest_v1.schema.json",
  "title": "EvoLake Campaign Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "mode",
    "mode_policy",
    "rng_seed",
    "budget",
    "objective",
    "schema_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "evolake_campaign_manifest_v1"
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "replay",
        "explore"
      ]
    },
    "mode_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_allowed",
        "explore_allowed",
        "default_mode"
      ],
      "properties": {
        "replay_allowed": {
          "type": "boolean"
        },
        "explore_allowed": {
          "type": "boolean"
        },
        "default_mode": {
          "type": "string",
          "enum": [
            "replay",
            "explore"
          ]
        }
      }
    },
    "rng_seed": {
      "type": "integer",
      "minimum": 0
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_generations",
        "max_time_s"
      ],
      "properties": {
        "max_generations": {
          "type": "integer",
          "minimum": 1
        },
        "max_time_s": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_metric",
        "secondary_metrics",
        "selection_rule"
      ],
      "properties": {
        "primary_metric": {
          "type": "string",
          "minLength": 1
        },
        "secondary_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selection_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schema_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
