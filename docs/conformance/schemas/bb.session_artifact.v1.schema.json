{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/schemas/bb.session_artifact.v1.schema.json",
  "title": "bb.session_artifact.v1",
  "description": "Session-level artifact used for replay/resume/fork/export/import/rollback workflows.",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "thread_id",
    "messages",
    "parts",
    "checkpoints",
    "decisions",
    "meta",
    "artifact_version",
    "content_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "integer",
      "minimum": 1
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9:_-]{8,128}$"
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/part"
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "meta": {
      "type": "object"
    },
    "supported_operations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "start",
          "resume",
          "fork",
          "export",
          "import",
          "rollback"
        ]
      }
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "compat_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "message": {
      "type": "object",
      "required": [
        "message_id",
        "role",
        "part_refs"
      ],
      "properties": {
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ]
        },
        "part_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "part": {
      "type": "object",
      "required": [
        "part_id",
        "kind",
        "data"
      ],
      "properties": {
        "part_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string"
        },
        "data": true,
        "created_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "additionalProperties": true
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "checkpoint_id",
        "sequence_no",
        "created_at"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "sequence_no": {
          "type": "integer",
          "minimum": 0
        },
        "parent_checkpoint": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "hash": {
          "type": "string",
          "pattern": "^[A-Za-z0-9:_-]{8,128}$"
        }
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "required": [
        "approval_id",
        "decision",
        "decided_at"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "deny"
          ]
        },
        "reason": {
          "type": "string"
        },
        "decider": {
          "type": "string"
        },
        "decided_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
