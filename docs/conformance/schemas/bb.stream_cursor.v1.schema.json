{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/schemas/bb.stream_cursor.v1.schema.json",
  "title": "bb.stream_cursor.v1",
  "description": "Resumable cursor checkpoint for projection/stream consumers.",
  "type": "object",
  "required": [
    "schema_version",
    "stream_id",
    "cursor",
    "prefix_hash",
    "last_ack_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "stream_id": {
      "type": "string",
      "minLength": 1
    },
    "cursor": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "prefix_hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9:_-]{8,128}$"
    },
    "last_ack_at": {
      "type": "string",
      "format": "date-time"
    },
    "resume_token": {
      "type": "string"
    },
    "consumer_id": {
      "type": "string"
    },
    "surface": {
      "type": "string",
      "enum": [
        "cli",
        "api",
        "tui",
        "ide",
        "web"
      ]
    }
  },
  "additionalProperties": true
}
