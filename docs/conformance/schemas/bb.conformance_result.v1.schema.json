{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/schemas/bb.conformance_result.v1.schema.json",
  "title": "bb.conformance_result.v1",
  "description": "Conformance suite execution result used for release gating.",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "target",
    "status",
    "failures",
    "duration_ms",
    "run_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "kind",
            "id"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "provider",
                "adapter",
                "surface",
                "schema",
                "runtime"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "error"
      ]
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "run_at": {
      "type": "string",
      "format": "date-time"
    },
    "tier": {
      "type": "string",
      "enum": [
        "always_passes",
        "usually_passes"
      ]
    },
    "report_ref": {
      "type": "string"
    }
  },
  "$defs": {
    "failure": {
      "type": "object",
      "required": [
        "test_id",
        "message"
      ],
      "properties": {
        "test_id": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "warning",
            "error"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failures": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
