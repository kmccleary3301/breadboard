{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:breadboard:schema:bb.delegation_task.v1",
  "title": "BreadBoard Delegation Task v1",
  "description": "Delegated subtask envelope for bounded recursion and explicit scope control.",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "depth",
    "scope",
    "goal",
    "constraints",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "type": "string",
      "minLength": 1
    },
    "depth": {
      "type": "integer",
      "minimum": 0
    },
    "scope": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "label"
          ],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1
            },
            "estimated_size": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 0
        },
        "max_subtasks": {
          "type": "integer",
          "minimum": 1
        },
        "scope_threshold": {
          "type": "number",
          "minimum": 0
        },
        "require_scope_approval_on_breach": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
