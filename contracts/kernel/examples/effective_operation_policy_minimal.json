{
  "schema_version": "bb.effective_operation_policy.v1",
  "policy_id": "policy_workspace_default",
  "applies_to": {
    "operation_id": "operation_chat_with_tools_001",
    "run_id": "run_001",
    "principal_ref": "principal://user/local",
    "provider_route_ref": "provider_route:route_primary_openai_gpt5"
  },
  "command_policy": {
    "surface": "command",
    "default_decision": "ask",
    "rules": [
      {
        "rule_id": "command_safe_readonly",
        "match": {
          "kind": "argv_prefix",
          "pattern": "git status",
          "scope_ref": "workspace://default"
        },
        "decision": "allow",
        "approval_required": false,
        "redaction_ref": null,
        "evidence_refs": ["evidence://policy/command-safe-readonly"]
      }
    ],
    "evidence_refs": ["evidence://policy/command"]
  },
  "file_policy": {
    "surface": "file",
    "default_decision": "ask",
    "rules": [
      {
        "rule_id": "file_workspace_read",
        "match": {
          "kind": "path_prefix",
          "pattern": "/workspace",
          "scope_ref": "workspace://default"
        },
        "decision": "allow",
        "approval_required": false,
        "redaction_ref": null,
        "evidence_refs": ["evidence://policy/file-workspace-read"]
      }
    ],
    "evidence_refs": ["evidence://policy/file"]
  },
  "network_policy": {
    "surface": "network",
    "default_decision": "deny",
    "rules": [
      {
        "rule_id": "network_provider_api",
        "match": {
          "kind": "endpoint_hash",
          "pattern": "sha256:3333333333333333333333333333333333333333333333333333333333333333",
          "scope_ref": "provider://openai"
        },
        "decision": "allow",
        "approval_required": false,
        "redaction_ref": "redaction://network/provider-url",
        "evidence_refs": ["evidence://policy/network-provider-api"]
      }
    ],
    "evidence_refs": ["evidence://policy/network"]
  },
  "tool_policy": {
    "surface": "tool",
    "default_decision": "ask",
    "rules": [
      {
        "rule_id": "tool_read_only",
        "match": {
          "kind": "tool_id",
          "pattern": "tool.read",
          "scope_ref": "tool-surface://default"
        },
        "decision": "allow",
        "approval_required": false,
        "redaction_ref": null,
        "evidence_refs": ["evidence://policy/tool-read-only"]
      }
    ],
    "evidence_refs": ["evidence://policy/tool"]
  },
  "resource_policy": {
    "surface": "resource",
    "default_decision": "ask",
    "rules": [
      {
        "rule_id": "resource_blob_project",
        "match": {
          "kind": "resource_scheme",
          "pattern": "bb+blob",
          "scope_ref": "project://default"
        },
        "decision": "allow",
        "approval_required": false,
        "redaction_ref": null,
        "evidence_refs": ["evidence://policy/resource-blob-project"]
      }
    ],
    "evidence_refs": ["evidence://policy/resource"]
  },
  "side_effect_policy": {
    "surface": "side_effect",
    "default_decision": "ask",
    "rules": [
      {
        "rule_id": "side_effect_no_external_write",
        "match": {
          "kind": "effect_class",
          "pattern": "external_write",
          "scope_ref": null
        },
        "decision": "deny",
        "approval_required": true,
        "redaction_ref": null,
        "evidence_refs": ["evidence://policy/no-external-write"]
      }
    ],
    "evidence_refs": ["evidence://policy/side-effect"]
  },
  "approvals": {
    "mode": "on_demand",
    "approval_refs": ["approval://workspace/default"],
    "approver_scope": "workspace-owner",
    "evidence_refs": ["evidence://policy/approvals"]
  },
  "budgets": {
    "token_budget": 200000,
    "cost_budget_usd": 25.0,
    "wall_time_seconds": 7200
  },
  "limits": {
    "concurrency": 4,
    "file_bytes": 10485760,
    "network_bytes": 52428800,
    "tool_calls": 200
  },
  "sandbox_refs": ["sandbox://local/default"],
  "placement_refs": ["placement://local-process/default"],
  "conditional_rules": [
    {
      "rule_id": "require_approval_for_large_network",
      "condition_ref": "condition://network-bytes-over-budget",
      "when_true": "ask",
      "when_false": "allow",
      "evidence_refs": ["evidence://policy/conditional-network-budget"]
    }
  ],
  "redaction_visibility": {
    "model_visible_paths": ["command_policy.default_decision", "tool_policy.default_decision"],
    "provider_visible_paths": ["budgets.token_budget"],
    "host_only_paths": ["approvals.approval_refs", "sandbox_refs"],
    "redacted_paths": ["auth_material", "network_policy.rules[0].match.pattern"],
    "redaction_policy_refs": ["redaction://default-secrets"]
  },
  "enforcement_evidence_refs": ["evidence://policy/enforcement/default"]
}
