{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.signal.v1.schema.json",
  "title": "bb.signal.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "signal_id",
    "code",
    "task_id",
    "authority_scope",
    "status",
    "source",
    "evidence_refs",
    "payload"
  ],
  "properties": {
    "schema_version": {"const": "bb.signal.v1"},
    "signal_id": {"type": "string", "minLength": 1},
    "code": {
      "enum": [
        "partial_complete",
        "merge_ready",
        "complete",
        "blocked",
        "no_progress",
        "retryable_failure",
        "catastrophic_failure",
        "human_required"
      ]
    },
    "task_id": {"type": "string", "minLength": 1},
    "parent_task_id": {"type": ["string", "null"]},
    "mission_task_id": {"type": ["string", "null"]},
    "authority_scope": {"enum": ["task", "mission"]},
    "status": {"enum": ["proposed", "accepted", "rejected"]},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "emitter_role"],
      "properties": {
        "kind": {
          "enum": [
            "assistant_content",
            "text_sentinel",
            "provider_finish",
            "tool_call",
            "runtime",
            "worker",
            "supervisor",
            "host",
            "system"
          ]
        },
        "emitter_role": {
          "enum": ["assistant", "worker", "supervisor", "host", "runtime", "system"]
        },
        "detail": {"type": ["string", "null"]}
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "validation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["accepted", "reasons", "validated_by"],
      "properties": {
        "accepted": {"type": "boolean"},
        "reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "validated_by": {"type": "string", "minLength": 1},
        "validated_at": {"type": ["number", "null"]}
      }
    }
  }
}
