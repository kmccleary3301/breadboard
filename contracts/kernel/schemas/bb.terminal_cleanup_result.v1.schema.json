{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb.terminal_cleanup_result.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "cleanup_id",
    "scope",
    "cleaned_session_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.terminal_cleanup_result.v1"
    },
    "cleanup_id": {"type": "string"},
    "scope": {"enum": ["single", "all", "filtered"]},
    "cleaned_session_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "failed_session_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
