{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.kernel.common.v1.schema.json",
  "title": "BreadBoard kernel shared definitions V1",
  "description": "Shared $defs for all BreadBoard kernel contracts. This file defines no record type; it is referenced via $ref.",
  "$defs": {
    "digest_sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Lowercase hex sha256 with mandatory 'sha256:' prefix. The only digest string form for new contracts."
    },
    "nullable_digest_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "hash_ref": {
      "type": "string",
      "pattern": "^[^#]+#sha256:[a-f0-9]{64}$",
      "description": "repo-root-relative-path#sha256:<64 lowercase hex>."
    },
    "row_hash_ref": {
      "type": "string",
      "pattern": "^[^#]+#[^#]+#sha256:[a-f0-9]{64}$",
      "description": "path#row_id#sha256:<hex> for row-addressed artifacts (e.g. ledger rows)."
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp. The only wall-clock form for new contracts."
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_.:/-]*$",
      "description": "Lowercase machine identifier."
    },
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_kind",
        "actor_id"
      ],
      "properties": {
        "actor_kind": {
          "enum": [
            "user",
            "agent",
            "subagent",
            "host",
            "provider",
            "system",
            "service"
          ]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_visible",
        "provider_visible",
        "host_visible"
      ],
      "properties": {
        "model_visible": {
          "type": "boolean"
        },
        "provider_visible": {
          "type": "boolean"
        },
        "host_visible": {
          "type": "boolean"
        },
        "redaction_state": {
          "enum": [
            "none",
            "redacted",
            "summarized",
            "elided"
          ],
          "default": "none"
        }
      },
      "description": "Canonical audience visibility. Boolean triple + optional redaction_state. Supersedes all enum dialects for NEW fields; legacy dialects are frozen and allowlisted (see CONTRACT_CONVENTIONS.md)."
    },
    "visibility_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_visible_paths",
        "provider_visible_paths",
        "host_only_paths",
        "redacted_paths"
      ],
      "properties": {
        "model_visible_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "provider_visible_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "host_only_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "redacted_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Canonical path-scoped visibility (matches bb.effective_operation_policy.v1.redaction_visibility minus policy refs)."
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "The ONLY open extension point on closed records. Consumers MUST ignore unknown keys. Producers MUST NOT place normative data here."
    },
    "argv_command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "cwd"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-root-relative working directory; '.' for checkout root."
        }
      }
    }
  }
}
