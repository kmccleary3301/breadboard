{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb.tool_binding.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "binding_id",
    "tool_id",
    "binding_kind"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.tool_binding.v1"
    },
    "binding_id": {"type": "string"},
    "tool_id": {"type": "string"},
    "binding_kind": {
      "enum": ["host", "sandbox", "service", "mcp", "delegated", "provider_hosted", "synthetic_only"]
    },
    "environment_selector": {
      "$ref": "bb.environment_selector.v1.schema.json"
    },
    "capability_id": {"type": ["string", "null"]},
    "placement_id": {"type": ["string", "null"]},
    "fallback_binding_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "policy_tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_mode": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
