{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.environment_selector.v2.schema.json",
  "title": "BreadBoard Environment Selector V2",
  "type": "object",
  "$comment": "Supersedes bb.environment_selector.v1. v1 is frozen as the embedded selector dialect used by bb.tool_binding.v1. v2 is the canonical standalone environment-selector record for new producers.",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "selector_id"
  ],
  "anyOf": [
    {"required": ["profile_ids"]},
    {"required": ["features"]},
    {"required": ["provider_families"]},
    {"required": ["driver_classes"]},
    {"required": ["image_ids"]},
    {"required": ["service_ids"]}
  ],
  "properties": {
    "schema_version": {
      "const": "bb.environment_selector.v2"
    },
    "selector_id": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
    },
    "profile_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "provider_families": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "driver_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "image_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "service_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
      }
    },
    "metadata": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/metadata"
    }
  }
}
