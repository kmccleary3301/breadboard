{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb.terminal_output_delta.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "terminal_session_id",
    "stream",
    "chunk_b64",
    "chunk_seq"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.terminal_output_delta.v1"
    },
    "terminal_session_id": {"type": "string"},
    "startup_call_id": {"type": ["string", "null"]},
    "causing_call_id": {"type": ["string", "null"]},
    "stream": {"enum": ["stdout", "stderr", "merged"]},
    "chunk_b64": {"type": "string"},
    "chunk_seq": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": false
}
