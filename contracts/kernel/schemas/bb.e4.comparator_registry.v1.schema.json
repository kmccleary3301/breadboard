{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.e4.comparator_registry.v1.schema.json",
  "title": "BreadBoard E4 comparator registry V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "generated_at_utc",
    "comparators"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.e4.comparator_registry.v1"
    },
    "registry_id": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
    },
    "generated_at_utc": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/timestamp_utc"
    },
    "comparators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "comparator_id",
          "entrypoint",
          "lane_ids",
          "comparator_class",
          "input_roles",
          "report_schema_version"
        ],
        "properties": {
          "comparator_id": {
            "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
          },
          "entrypoint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "module",
              "callable"
            ],
            "properties": {
              "module": {
                "type": "string",
                "minLength": 1,
                "description": "Importable module path, e.g. 'conformance.comparators.oh_my_pi'."
              },
              "callable": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "lane_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "comparator_class": {
            "enum": [
              "deterministic_replay",
              "environment_bound",
              "projection_equal",
              "hash_only_legacy"
            ]
          },
          "input_roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "report_schema_version": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "dated_at_utc": {
                "$ref": "bb.kernel.common.v1.schema.json#/$defs/timestamp_utc"
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "comparator_class": {
                  "enum": [
                    "environment_bound",
                    "hash_only_legacy"
                  ]
                }
              },
              "required": [
                "comparator_class"
              ]
            },
            "then": {
              "required": [
                "metadata"
              ],
              "properties": {
                "metadata": {
                  "required": [
                    "reason"
                  ]
                }
              }
            }
          }
        ]
      }
    }
  }
}
