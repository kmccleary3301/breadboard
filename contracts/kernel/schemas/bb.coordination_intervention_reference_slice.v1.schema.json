{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.coordination_intervention_reference_slice.v1.schema.json",
  "title": "bb.coordination_intervention_reference_slice.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "supervisor_task_id",
    "worker_task_id",
    "signal",
    "review_verdict",
    "supervisor_directive",
    "host_directive",
    "unresolved_interventions_before",
    "resolved_interventions_after",
    "events"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.coordination_intervention_reference_slice.v1"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "supervisor_task_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_task_id": {
      "type": "string",
      "minLength": 1
    },
    "signal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "signal_id",
        "code",
        "task_id",
        "status"
      ],
      "properties": {
        "schema_version": {
          "const": "bb.signal.v1"
        },
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "const": "human_required"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "accepted",
            "rejected",
            "proposed"
          ]
        }
      }
    },
    "review_verdict": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "verdict_id",
        "verdict_code",
        "subject"
      ],
      "properties": {
        "schema_version": {
          "const": "bb.review_verdict.v1"
        },
        "verdict_id": {
          "type": "string",
          "minLength": 1
        },
        "verdict_code": {
          "const": "human_required"
        },
        "subject": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "supervisor_directive": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "directive_id",
        "directive_code",
        "issuer_role",
        "target_task_id"
      ],
      "properties": {
        "schema_version": {
          "const": "bb.directive.v1"
        },
        "directive_id": {
          "type": "string",
          "minLength": 1
        },
        "directive_code": {
          "const": "escalate"
        },
        "issuer_role": {
          "const": "supervisor"
        },
        "target_task_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "host_directive": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "directive_id",
        "directive_code",
        "issuer_role",
        "target_task_id"
      ],
      "properties": {
        "schema_version": {
          "const": "bb.directive.v1"
        },
        "directive_id": {
          "type": "string",
          "minLength": 1
        },
        "directive_code": {
          "enum": [
            "continue",
            "checkpoint",
            "terminate"
          ]
        },
        "issuer_role": {
          "const": "host"
        },
        "target_task_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "unresolved_interventions_before": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "intervention_id",
          "status",
          "review_verdict_id"
        ],
        "properties": {
          "intervention_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "pending"
          },
          "review_verdict_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "resolved_interventions_after": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "intervention_id",
          "status",
          "review_verdict_id",
          "host_responses"
        ],
        "properties": {
          "intervention_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "resolved"
          },
          "review_verdict_id": {
            "type": "string",
            "minLength": 1
          },
          "host_responses": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "event_id",
          "type",
          "payload"
        ],
        "properties": {
          "event_id": {
            "type": "integer",
            "minimum": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
