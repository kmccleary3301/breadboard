{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb.tool_spec.v1.schema.json",
  "title": "BreadBoard Tool Spec V1",
  "type": "object",
  "$comment": "First-pass tool spec scaffold.",
  "additionalProperties": true,
  "required": ["schemaVersion", "name", "description", "inputSchema"],
  "properties": {
    "schemaVersion": { "const": "bb.tool_spec.v1" },
    "name": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "description": { "type": "string" },
    "inputSchema": { "type": "object", "additionalProperties": true },
    "outputSchema": { "type": "object", "additionalProperties": true },
    "approvalPolicy": { "type": "object", "additionalProperties": true },
    "visibility": { "type": "object", "additionalProperties": true },
    "capabilityTags": { "type": "array", "items": { "type": "string" } }
  }
}
