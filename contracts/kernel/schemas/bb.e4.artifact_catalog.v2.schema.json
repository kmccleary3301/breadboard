{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.e4.artifact_catalog.v2.schema.json",
  "title": "BreadBoard E4 artifact catalog V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "catalog_id",
    "generated_at_utc",
    "revision",
    "entries",
    "segments",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.e4.artifact_catalog.v2"
    },
    "catalog_id": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
    },
    "generated_at_utc": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/timestamp_utc"
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Content-versioned monotonic revision of the catalog's role-keyed stable evidence subset; unchanged by claim-derived entry churn. Segment hashes are content addresses and are authoritative for support-claim v3 binding."
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/catalog_entry"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/catalog_segment"
      },
      "description": "Deterministic per-lane partitions plus the shared partition. JSON Schema cannot express uniqueness of segment_id; validators enforce it."
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_count",
        "entries_hash",
        "stable_entries_hash",
        "segments_hash"
      ],
      "properties": {
        "entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "entries_hash": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256",
          "description": "sha256 of canonical JSON bytes of the full entries array."
        },
        "stable_entries_hash": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256",
          "description": "sha256 of canonical JSON bytes of all catalog entries classified stable by explicit lane-role-suffix and e4_static role-id rules."
        },
        "segments_hash": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256",
          "description": "sha256 of canonical JSON bytes of the segments array."
        }
      }
    }
  },
  "$defs": {
    "catalog_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_id",
        "path",
        "sha256",
        "bytes",
        "exists",
        "artifact_kind",
        "derived_from",
        "generated_by"
      ],
      "properties": {
        "role_id": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier",
          "description": "Stable logical key, e.g. 'oh_my_pi_p6_0_l4:capture'. Unique across entries (validator-enforced; JSON Schema cannot express it)."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-root-relative for checkout files; 'docs_tmp/...' allowed for plan-root artifacts."
        },
        "sha256": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "enum": [
            "freeze",
            "capture",
            "raw_source",
            "replay",
            "comparator",
            "parity_results",
            "secret_scan",
            "support_claim",
            "evidence_manifest",
            "node_gate",
            "ledger",
            "score_row",
            "report",
            "schema",
            "script",
            "fixture",
            "config",
            "other"
          ]
        },
        "lane_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "media_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "derived_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "role_ids of inputs."
        },
        "generated_by": {
          "type": "string",
          "minLength": 1,
          "description": "Producing script path, or 'manual'."
        }
      }
    },
    "catalog_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "entry_count",
        "entries_hash",
        "stable_entries_hash"
      ],
      "properties": {
        "segment_id": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier",
          "description": "Lane id for lane-bound entries, or 'shared' for entries without lane_id."
        },
        "entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "entries_hash": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256",
          "description": "sha256 of canonical JSON bytes of all entries in this segment."
        },
        "stable_entries_hash": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/digest_sha256",
          "description": "sha256 of canonical JSON bytes of stable entries in this segment."
        }
      }
    }
  }
}
