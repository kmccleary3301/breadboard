{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/kernel/schemas/bb.tool_execution_outcome.v2.schema.json",
  "title": "BreadBoard Tool Execution Outcome V2",
  "type": "object",
  "$comment": "Supersedes bb.tool_execution_outcome.v1. v1 is frozen for accepted evidence. Migration map: docs/contracts/CONTRACT_CONVENTIONS.md#v1-to-v2-runtime-records.",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "call_id",
    "terminal_state",
    "completed_at_utc"
  ],
  "properties": {
    "schema_version": {
      "const": "bb.tool_execution_outcome.v2"
    },
    "call_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_state": {
      "enum": [
        "completed",
        "failed",
        "cancelled",
        "denied",
        "timed_out",
        "errored"
      ],
      "$comment": "errored = engine/sandbox-level error outside tool-reported failure; legitimizes the observed TS producer at sdk/ts-kernel-core/src/turns.ts errored path."
    },
    "completed_at_utc": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/timestamp_utc"
    },
    "result": true,
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "$ref": "bb.kernel.common.v1.schema.json#/$defs/identifier"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "$ref": "bb.kernel.common.v1.schema.json#/$defs/nullable_digest_sha256"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stdout_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "stderr_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "side_effect_refs": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/evidence_refs"
    },
    "visibility": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/visibility"
    },
    "metadata": {
      "$ref": "bb.kernel.common.v1.schema.json#/$defs/metadata"
    }
  }
}
