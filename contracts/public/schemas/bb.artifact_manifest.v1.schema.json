{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/public/schemas/bb.artifact_manifest.v1.schema.json",
  "title": "BreadBoard Artifact Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "session_id", "artifacts"],
  "properties": {
    "schema_version": {"const": "bb.artifact_manifest.v1"},
    "manifest_id": {"type": "string", "pattern": "^artifact_manifest:[0-9a-f]{64}$"},
    "session_id": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest", "size_bytes", "media_type"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$"},
          "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "media_type": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
