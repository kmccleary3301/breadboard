{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://breadboard.dev/contracts/public/schemas/bb.public_record_surface.v1.schema.json",
  "title": "BreadBoard candidate public record surface V1",
  "type": "object", "additionalProperties": false,
  "required": ["contract_id", "version", "status", "frozen_public_surface", "roles"],
  "properties": {
    "contract_id": {"const": "bb.public_record_surface.v1"}, "version": {"const": 1}, "status": {"const": "candidate"},
    "frozen_public_surface": {"type": "object", "additionalProperties": false, "required": ["contract_id", "sha256"], "properties": {"contract_id": {"const": "bb.north_star.public_surface.v1"}, "sha256": {"const": "sha256:72817b7b1bc5e5d10f752acb48157491aaeb3eb268337461a4fd6f0bd10cbfe0"}}},
    "roles": {"type": "array", "minItems": 24, "maxItems": 24, "items": {"type": "object", "additionalProperties": false, "required": ["role_id", "label", "schema_ids", "status", "owner"], "properties": {"role_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "label": {"type": "string", "minLength": 1}, "schema_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^bb\\.[a-z0-9_.]+\\.v[0-9]+$"}}, "status": {"const": "candidate"}, "owner": {"type": "string", "minLength": 1}}}}
  }
}
